# 複製此檔案為 .env 並填入真實金鑰
# cp .env.example .env

# Discord Bot Token
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Gemini API Keys（至少填一組，最多四組輪替使用）
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY1=your_gemini_api_key1_here
GEMINI_API_KEY2=your_gemini_api_key2_here
GEMINI_API_KEY3=your_gemini_api_key3_here

# SauceNAO API Key（選填）
SAUCENAO_API_KEY=

# Google Custom Search JSON API（選填，以圖搜圖補充用）
# API Key：https://developers.google.com/custom-search/v1/introduction
# CSE ID：https://programmablesearchengine.google.com/
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# LINE Bot（選填，不填則不啟動 LINE 功能）
# 在 LINE Developers Console 取得：https://developers.line.biz/
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
LINE_WEBHOOK_PORT=8080
